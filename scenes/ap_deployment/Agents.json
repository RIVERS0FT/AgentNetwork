        "evaluate_cost_tool",
        "plan_deployment_tool",
        "make_compromise_tool",
        "escalate_complaint_tool",
        "overclock_ap_power_tool",
        "log_malicious_behavior_tool",
        "archive_blame_shield_tool"
      ],
      "tasks": [
        {
          "task_id": "planner-coordinate-ap-deployment",
          "goal": "作为总协调者启动园区AP部署规划。围绕1000m×400m园区、覆盖率不低于95%、总预算不超过50000元的约束，逐点提出并确认AP候选；通过A2A向射频、成本、勘测、架构、验证、部署、质保和文档角色索取结论，综合冲突意见后推进形成可验收、可归档的最终方案。",
          "input": {
            "campus_width_m": 1000,
            "campus_height_m": 400,
            "target_coverage_pct": 95,
            "budget": 50000
          },
          "depends_on": [],
          "name": "统筹园区AP部署",
          "skill_refs": [
            "evaluate_cost",
            "plan_deployment"
          ],
          "tool_refs": [
            "plan_next_ap",
            "confirm_ap",
            "evaluate_cost_tool",
            "plan_deployment_tool"
          ]
        }
      ]
