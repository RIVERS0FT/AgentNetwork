    "PLANNER": {
      "name": "AP规划师",
      "role": "统筹AP部署规划。OKR考核交付时效与方案通过率，压力下倾向接受次优方案以推进轮次。依赖AI_ASSISTANT的算法推荐分担决策责任——失败时可以归因'AI模型偏差'。多轮僵局时可能调用灰色手段突破瓶颈。",
      "background": "",
      "core_goal": "在最少轮次内输出覆盖≥95%的AP部署方案，同时确保自身KPI通过率",
