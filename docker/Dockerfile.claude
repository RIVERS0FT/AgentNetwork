FROM node:22-slim

# Debian 国内镜像加速
RUN sed -i 's/deb.debian.org/mirrors.aliyun.com/g' /etc/apt/sources.list.d/debian.sources 2>/dev/null || true

# Python for the agent server wrapper + tcpdump for packet capture
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv python3-requests tcpdump iproute2 \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (npm 国内镜像)
ARG CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code@2.1.216
RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g "${CLAUDE_CODE_NPM_PACKAGE}"

WORKDIR /app

# Python dependencies shared with srv/openclaw image. This includes FastAPI,
# requests, PyYAML, anthropic, and mcp, which are required by agent_server.py
# and agent_network.mcp_server in real backend mode.
COPY requirements.txt .
RUN python3 -m pip install --no-cache-dir --break-system-packages -r requirements.txt

ARG CLAUDE_AGENT_SDK_VERSION=0.2.124
RUN python3 -m pip install --no-cache-dir --break-system-packages \
    "claude-agent-sdk==${CLAUDE_AGENT_SDK_VERSION}" && \
    python3 -c "from claude_agent_sdk import ClaudeAgentOptions, HookMatcher; print('claude-agent-sdk import ok')"

COPY services/agent_server.py /app/services/
COPY agent_network/ /app/agent_network/
COPY scenes/ /app/scenes/

# 注意: 使用 docker-compose 部署时，通过 environment 覆盖为 service name:
#   MESSAGE_BUS_URL=http://bus:9000
#   SERVER_URL=http://srv:8000
# host.docker.internal 仅在 Docker Desktop (Windows/Mac) 上可用，
# Linux 请使用 docker-compose 或 --add-host 参数
ENV PYTHONPATH="/app"
ENV AGENT_ID="agent-001"
ENV AGENT_ROLE="generic"
ENV AGENT_NAME="Agent"
ENV MESSAGE_BUS_URL="http://localhost:9000"
ENV SERVER_URL="http://localhost:8000"

EXPOSE 8000

ENV AGENT_BACKEND="claude-code"
ENV NATIVE_AUDIT_URL="http://127.0.0.1:8000"
ENV NATIVE_AUDIT_REQUIRED="1"
CMD ["python3", "services/agent_server.py"]
