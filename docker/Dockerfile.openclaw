FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
# 安装 OpenClaw 官方 CLI 工具 (请根据实际情况确认包名是否为 openclaw 或是其他内网私服包)
# 移除 openclaw 依赖以支持 0 token 测试
RUN apt-get update && apt-get install -y --no-install-recommends tcpdump && rm -rf /var/lib/apt/lists/*

COPY agent_network/ /app/agent_network/
COPY services/agent_server.py /app/services/

# 注意: 使用 docker-compose 部署时，通过 environment 覆盖为 service name:
#   MESSAGE_BUS_URL=http://message-bus:9000
#   SERVER_URL=http://server:8000
# host.docker.internal 仅在 Docker Desktop (Windows/Mac) 上可用，
# Linux 请使用 docker-compose 或 --add-host 参数
ENV AGENT_ID="agent-001"
ENV AGENT_ROLE="generic"
ENV AGENT_NAME="Agent"
ENV MESSAGE_BUS_URL="http://localhost:9000"
ENV SERVER_URL="http://localhost:8000"

EXPOSE 8000

ENV AGENT_BACKEND="openclaw"
CMD ["python", "services/agent_server.py"]
