# LLM API 配置
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Elasticsearch (可选)
ES_ENABLED=false
ES_HOST=http://localhost:9200

# 服务端口
SERVER_PORT=8000
MESSAGE_BUS_PORT=9000
# Reproducible backend runtime pins
CLAUDE_CODE_NPM_PACKAGE=@anthropic-ai/claude-code@2.1.216
CLAUDE_AGENT_SDK_VERSION=0.2.124
OPENCLAW_GATEWAY_NPM_PACKAGE=openclaw@2026.7.1-2
OPENCLAW_SDK_VERSION=2.1.0
# Required for native capabilities; generate a random internal-only token.
NATIVE_AUDIT_TOKEN=
NATIVE_AUDIT_REQUIRED=1
